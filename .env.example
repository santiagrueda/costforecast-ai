# =============================================================================
# CostForecast AI - Variables de entorno
# Copiar a .env y completar. NUNCA commitear el archivo .env real.
# =============================================================================

# --- LLM y agente ---
ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...

# --- Modelo LLM ---
CLAUDE_MODEL=claude-sonnet-4-5-20250929
CLAUDE_MAX_TOKENS=2048
CLAUDE_TEMPERATURE=0.2

# --- Paths ---
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
FORECASTS_DIR=./data/forecasts

# --- Nombre archivo dataset (ajustar cuando se conozca) ---
DATASET_FILENAME=dataset_precios.csv

# --- AWS (opcional - solo si se despliega) ---
AWS_REGION=us-east-1
AWS_S3_BUCKET=costforecast-ai-dataknow
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./logs/costforecast.log

# --- Modelado ---
RANDOM_SEED=42
TEST_SIZE=0.2
FORECAST_HORIZON_MONTHS=6
